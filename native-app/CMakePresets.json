{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-ninja",
      "displayName": "Base Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "qt-mingw",
      "displayName": "Qt MinGW",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/Qt/6.8.0/mingw_64"
      }
    },
    {
      "name": "qt-msvc",
      "displayName": "Qt MSVC",
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/Qt/6.8.0/msvc2022_64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build",
      "configurePreset": "base-ninja"
    }
  ]
}
